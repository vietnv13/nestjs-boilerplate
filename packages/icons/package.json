{
  "name": "@workspace/icons",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "pnpm generate && tsdown",
    "dev": "tsdown --watch",
    "generate": "rm -f src/icons/*.tsx && svgr --config-file svgr.config.mjs --filename-case kebab --ext tsx --no-index --out-dir src/icons -- src/svg"
  },
  "dependencies": {
    "react": "^19.2.3"
  },
  "devDependencies": {
    "@svgr/cli": "^8.1.0",
    "@types/react": "^19.2.7",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "tsdown": "^0.15.12",
    "typescript": "^5.9.3"
  }
}
