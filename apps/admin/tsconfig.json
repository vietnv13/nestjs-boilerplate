{
  "extends": "@workspace/typescript-config/tsconfig.nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@workspace/shadcn-ui/globals.css": ["../../packages/shadcn-ui/src/styles/index.css"],
      "@workspace/shadcn-ui/*": ["../../packages/shadcn-ui/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
