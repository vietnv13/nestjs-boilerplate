# Environment Configuration
# Copy this file to .env and modify as needed

# App environment
NODE_ENV=development

# App port
PORT=3000

# Database connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nestjs

# Database connection pool config
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=10000

# Swagger auto-login config (dev only)
SWAGGER_TEST_EMAIL=test@example.com
SWAGGER_TEST_PASSWORD=TestPassword123

# Better Auth config - TODO: allow CORS, keep consistent with unified config
BETTER_AUTH_SECRET=dev-secret-change-me-in-production-min-32-chars
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Scheduler config
SCHEDULER_ENABLED=true

# Storage config
# Driver: local | s3
STORAGE_DRIVER=local

# Local driver
# Files are written to this directory (relative to repo root when running locally)
STORAGE_LOCAL_DIR=uploads
# Optional public base URL for building absolute URLs (e.g. https://api.example.com)
# STORAGE_PUBLIC_BASE_URL=

# S3 driver (required when STORAGE_DRIVER=s3)
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=
# STORAGE_S3_ENDPOINT=           # optional, e.g. https://s3.amazonaws.com or MinIO endpoint
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=
# STORAGE_S3_FORCE_PATH_STYLE=false
# STORAGE_S3_PUBLIC_BASE_URL=    # optional, if bucket is public/CDN-backed
# STORAGE_S3_SIGNED_URL_EXPIRES_SEC=900
